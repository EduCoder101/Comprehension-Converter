---
interface Props {
  title?: string;
}
const { title = 'Reading Comprehension Hub' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --blue: #4f8cff;
        --blue-light: #e8f0ff;
        --purple: #7c5cfc;
        --purple-light: #f0ecff;
        --orange: #ff8a3d;
        --orange-light: #fff3ea;
        --green: #2bc88f;
        --green-light: #e5faf1;
        --pink: #ff6b9d;
        --pink-light: #fff0f5;
        --text: #1e293b;
        --text-light: #64748b;
        --bg: #f8faff;
        --card: #ffffff;
        --border: #e2e8f0;
        --radius: 16px;
        --shadow: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.06);
        --shadow-lg: 0 4px 6px rgba(0,0,0,0.04), 0 10px 24px rgba(0,0,0,0.08);
        --shadow-hover: 0 8px 16px rgba(0,0,0,0.08), 0 16px 32px rgba(0,0,0,0.1);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        min-height: 100vh;
      }
      .hero {
        background: linear-gradient(135deg, #4f8cff 0%, #7c5cfc 50%, #ff6b9d 100%);
        padding: 60px 24px 80px;
        text-align: center;
        color: white;
        position: relative;
        overflow: hidden;
      }
      .hero::before {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.12) 0%, transparent 60%),
                    radial-gradient(circle at 70% 80%, rgba(255,255,255,0.08) 0%, transparent 50%);
        pointer-events: none;
      }
      .hero-content { position: relative; max-width: 720px; margin: 0 auto; }
      .hero-badge {
        display: inline-block;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        padding: 6px 16px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        margin-bottom: 20px;
      }
      .hero h1 {
        font-size: 2.8rem;
        font-weight: 800;
        line-height: 1.15;
        margin-bottom: 16px;
        letter-spacing: -0.02em;
      }
      .hero p {
        font-size: 1.15rem;
        opacity: 0.92;
        max-width: 560px;
        margin: 0 auto;
        line-height: 1.7;
      }
      .wave-divider { margin-top: -2px; background: var(--bg); }
      .wave-divider svg { display: block; width: 100%; height: 60px; }
      .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
      .tools-section {
        margin-top: -40px;
        padding-bottom: 48px;
        position: relative;
        z-index: 10;
      }
      .tools-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 24px;
      }
      .tool-card {
        background: var(--card);
        border-radius: var(--radius);
        padding: 32px 28px;
        box-shadow: var(--shadow);
        transition: transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        color: var(--text);
        display: flex;
        flex-direction: column;
        border: 1px solid var(--border);
        position: relative;
        overflow: hidden;
      }
      .tool-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-hover);
      }
      .tool-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 4px;
      }
      .tool-card.blue::before { background: linear-gradient(90deg, var(--blue), #6ba3ff); }
      .tool-card.purple::before { background: linear-gradient(90deg, var(--purple), #9b82ff); }
      .tool-card.green::before { background: linear-gradient(90deg, var(--green), #5de0b0); }
      .tool-icon {
        width: 56px; height: 56px;
        border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.6rem;
        margin-bottom: 18px;
      }
      .tool-card.blue .tool-icon { background: var(--blue-light); }
      .tool-card.purple .tool-icon { background: var(--purple-light); }
      .tool-card.green .tool-icon { background: var(--green-light); }
      .tool-card h3 { font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; }
      .tool-card p { font-size: 0.95rem; color: var(--text-light); flex: 1; margin-bottom: 16px; }
      .tool-link {
        display: inline-flex; align-items: center; gap: 6px;
        font-weight: 600; font-size: 0.95rem;
      }
      .tool-card.blue .tool-link { color: var(--blue); }
      .tool-card.purple .tool-link { color: var(--purple); }
      .tool-card.green .tool-link { color: var(--green); }
      .tool-link .arrow { transition: transform 0.2s; }
      .tool-card:hover .tool-link .arrow { transform: translateX(4px); }
      .section-header { text-align: center; padding: 48px 0 32px; }
      .section-header h2 { font-size: 1.8rem; font-weight: 800; color: var(--text); margin-bottom: 8px; }
      .section-header p { color: var(--text-light); font-size: 1.05rem; }
      .library-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        padding-bottom: 48px;
      }
      .library-card-wrapper { position: relative; }
      .library-card {
        background: var(--card);
        border-radius: var(--radius);
        padding: 24px;
        box-shadow: var(--shadow);
        border: 1px solid var(--border);
        transition: transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        color: var(--text);
        display: block;
        position: relative;
      }
      .library-card:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow-lg);
      }
      .library-tag {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 8px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 12px;
      }
      .tag-naplan { background: var(--blue-light); color: var(--blue); }
      .tag-comprehension { background: var(--orange-light); color: var(--orange); }
      .tag-new { background: var(--pink-light); color: var(--pink); }
      .library-card h3 { font-size: 1.05rem; font-weight: 700; margin-bottom: 6px; }
      .library-card .meta { font-size: 0.85rem; color: var(--text-light); margin-bottom: 12px; }
      .library-card .meta span { margin-right: 12px; }
      .start-btn {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 18px; border-radius: 10px;
        font-size: 0.9rem; font-weight: 600;
        color: white; background: var(--blue);
        text-decoration: none;
        transition: background 0.15s;
      }
      .start-btn:hover { background: #3d7aee; }
      .add-test-card {
        background: var(--card);
        border-radius: var(--radius);
        padding: 24px;
        border: 2px dashed var(--border);
        display: flex;
        align-items: center; justify-content: center;
        flex-direction: column;
        gap: 8px;
        cursor: pointer;
        transition: all 0.2s;
        color: var(--text-light);
        min-height: 160px;
      }
      .add-test-card:hover {
        border-color: var(--purple);
        color: var(--purple);
        background: var(--purple-light);
      }
      .add-test-card .plus { font-size: 2rem; font-weight: 300; line-height: 1; }
      .add-test-card span { font-weight: 600; font-size: 0.95rem; }
      .card-actions {
        position: absolute;
        top: 12px; right: 12px;
        display: none; gap: 6px; z-index: 10;
      }
      .library-card-wrapper:hover .card-actions { display: flex; }
      .card-action-btn {
        width: 28px; height: 28px;
        border-radius: 50%;
        border: none; font-size: 0.85rem;
        cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background 0.15s;
      }
      .copy-link-btn { background: var(--blue-light); color: var(--blue); }
      .copy-link-btn:hover { background: #d0e2ff; }
      .copy-link-btn.copied { background: var(--green-light); color: var(--green); }
      .delete-btn { background: #fee2e2; color: #ef4444; }
      .delete-btn:hover { background: #fecaca; }
      .how-section {
        background: var(--card);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 40px 36px;
        margin-bottom: 48px;
        box-shadow: var(--shadow);
      }
      .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 24px;
      }
      .step-card { text-align: center; padding: 20px 16px; }
      .step-num {
        width: 44px; height: 44px;
        border-radius: 50%;
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 800; font-size: 1.1rem;
        color: white;
        margin-bottom: 14px;
      }
      .step-card:nth-child(1) .step-num { background: var(--blue); }
      .step-card:nth-child(2) .step-num { background: var(--purple); }
      .step-card:nth-child(3) .step-num { background: var(--orange); }
      .step-card:nth-child(4) .step-num { background: var(--green); }
      .step-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 6px; }
      .step-card p { font-size: 0.9rem; color: var(--text-light); line-height: 1.6; }
      .teacher-zone {
        background: linear-gradient(135deg, #f0ecff 0%, #e8f0ff 100%);
        border-radius: var(--radius);
        border: 1px solid var(--border);
        padding: 28px 32px;
        margin-bottom: 48px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
      }
      .teacher-zone-text h3 { font-size: 1.1rem; font-weight: 700; margin-bottom: 4px; }
      .teacher-zone-text p { font-size: 0.9rem; color: var(--text-light); }
      .teacher-zone-sheet-url { margin-top: 14px; }
      .teacher-zone-sheet-url label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 4px;
      }
      .teacher-zone-sheet-url .sheet-input-row {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
      }
      .teacher-zone-sheet-url input {
        flex: 1;
        min-width: 200px;
        padding: 8px 12px;
        border: 2px solid var(--border);
        border-radius: 8px;
        font-size: 0.9rem;
      }
      .teacher-zone-sheet-url .sheet-status { font-size: 0.8rem; color: var(--text-light); margin-top: 4px; display: block; }
      .teacher-zone-links { display: flex; gap: 12px; flex-wrap: wrap; }
      .tz-link {
        padding: 10px 20px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.15s;
        border: 2px solid transparent;
      }
      .tz-link.primary { background: var(--purple); color: white; }
      .tz-link.primary:hover { background: #6a4ae0; }
      .tz-link.secondary { background: white; color: var(--purple); border-color: var(--purple); }
      .tz-link.secondary:hover { background: var(--purple-light); }
      .footer {
        text-align: center;
        padding: 32px 24px;
        color: var(--text-light);
        font-size: 0.85rem;
        border-top: 1px solid var(--border);
      }
      .modal-overlay {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.4);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        padding: 20px;
      }
      .modal-overlay.active { display: flex; }
      .modal {
        background: var(--card);
        border-radius: var(--radius);
        padding: 36px;
        max-width: 520px;
        width: 100%;
        box-shadow: var(--shadow-lg);
      }
      .modal h2 { font-size: 1.3rem; font-weight: 700; margin-bottom: 20px; }
      .modal label { display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 6px; color: var(--text); }
      .modal input, .modal select {
        width: 100%;
        padding: 10px 14px;
        border: 2px solid var(--border);
        border-radius: 10px;
        font-size: 1rem;
        font-family: inherit;
        margin-bottom: 16px;
        transition: border-color 0.15s;
      }
      .modal input:focus, .modal select:focus { border-color: var(--purple); outline: none; }
      .modal-actions { display: flex; gap: 12px; justify-content: flex-end; margin-top: 8px; }
      .modal-btn {
        padding: 10px 24px;
        border-radius: 10px;
        font-size: 0.95rem;
        font-weight: 600;
        border: none;
        cursor: pointer;
        transition: all 0.15s;
      }
      .modal-btn.cancel { background: #f1f5f9; color: var(--text); }
      .modal-btn.cancel:hover { background: #e2e8f0; }
      .modal-btn.save { background: var(--purple); color: white; }
      .modal-btn.save:hover { background: #6a4ae0; }
      .toast {
        position: fixed;
        bottom: 24px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--text);
        color: white;
        padding: 12px 24px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 500;
        box-shadow: var(--shadow-lg);
        z-index: 2000;
        animation: toastIn 0.3s ease, toastOut 0.3s ease 2s forwards;
      }
      @keyframes toastIn {
        from { opacity: 0; transform: translateX(-50%) translateY(10px); }
        to { opacity: 1; transform: translateX(-50%) translateY(0); }
      }
      @keyframes toastOut { from { opacity: 1; } to { opacity: 0; } }
      @media (max-width: 640px) {
        .hero h1 { font-size: 2rem; }
        .hero { padding: 40px 20px 60px; }
        .tools-grid { grid-template-columns: 1fr; }
        .steps-grid { grid-template-columns: 1fr 1fr; }
        .teacher-zone { flex-direction: column; text-align: center; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
